{
  // Editor
  "editor.fontFamily": "'Monaspace Neon', monospace",
  "editor.fontLigatures": "'ss01', 'ss03', 'ss06', 'calt'",
  "editor.fontWeight": 400,
  "editor.fontSize": 14,
  "editor.lineHeight": 22,
  "editor.rulers": [80],
  "editor.renderWhitespace": "trailing",
  "editor.cursorBlinking": "phase",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.scrollBeyondLastLine": false,
  "editor.accessibilitySupport": "off",
  "editor.codeLens": false,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.emptySelectionClipboard": false,
  "editor.minimap.autohide": "mouseover",

  // Workbench
  "workbench.colorTheme": "Jet dark",
  "workbench.preferredDarkColorTheme": "Darcula",
  "workbench.preferredHighContrastColorTheme": "Darcula",
  "workbench.fontAliasing": "antialiased",
  "workbench.settings.editor": "json",
  "workbench.startupEditor": "none",
  "workbench.list.smoothScrolling": true,
  "workbench.tree.renderIndentGuides": "onHover",
  "workbench.statusBar.visible": false,
  "workbench.editor.showTabs": "single",
  "workbench.tips.enabled": false,
  "workbench.activityBar.location": "top",
  "workbench.editor.centeredLayoutAutoActivate": true,

  // Zen Mode
  "zenMode.centerLayout": true,
  "zenMode.restore": true,

  // Window
  "window.commandCenter": false,

  // Explorer
  "explorer.autoReveal": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/node_modules/": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/dist/**": true,
    "**/.git": true
  },

  // Git
  "git.mergeEditor": true,

  // Remote SSH
  "remote.SSH.useLocalServer": false,

  // Vim
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.handleKeys": {
    "<C-f>": false // For Linux, find shortcut
  },

  // Telemetry
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": false
}
